<?xml version="1.0"?>
<root main_tree_to_execute="Main">

  <BehaviorTree ID="Main">
    <Repeat num_cycles="-1">
      <Sequence name="ManualSelectThenRun">

        <WaitManualFloorRequest
          elevator_topic="/elevator/floor_request"
          stairs_topic="/stairs/floor_request"
          mode="{mode}"
          target_floor="{target_floor}" />

        <GetCurrentFloor
            map_frame="map"
            base_frame="base_link"
            floor0_z="0.0"
            floor1_z="5.0"
            floor2_z="10.0"
            current_floor="{current_floor}"/>

        <Fallback name="BranchByMode">

          <Sequence name="ElevatorBranch">
            <CheckStringEquals key="{mode}" value="elevator"/>

            <SubTree ID="ElevatorSubtree" __shared_blackboard="true" target_floor="{target_floor}" current_floor="{current_floor}"/>
          </Sequence>

          <Sequence name="StairsBranch">
            <CheckStringEquals key="{mode}" value="stairs"/>
            <SubTree ID="StairsSubtree" __shared_blackboard="true" target_floor="{target_floor}" current_floor="{current_floor}"/>
          </Sequence>

        </Fallback>

        <SelectFloorConfig
          target_floor="{target_floor}"
          config_file="/home/home/ros2_ws/src/RCI_quadruped_robot_navigation/bt/door_bt/config/floor_config.yaml"
          door_yaml="{door_yaml}" />

        <PublishDoorYaml yaml="{door_yaml}" topic="/door_controller/config_yaml"/>
      </Sequence>
    </Repeat>
  </BehaviorTree>


  <BehaviorTree ID="ElevatorSubtree">
    <Sequence name="ChangeFloorSequence_Elevator">
    
      <SelectNearestElevator
          world_frame="map"
          base_frame="base_link"
          lift1_yaml="/home/home/ros2_ws/src/RCI_quadruped_robot_navigation/bt/elevator_bt/config/elevator_lift1.yaml"
          lift2_yaml="/home/home/ros2_ws/src/RCI_quadruped_robot_navigation/bt/elevator_bt/config/elevator_lift2.yaml"
          current_floor="{current_floor}"
          elev_yaml="{elev_yaml}"
          elevator_ns="{elevator_ns}"
          elevator_entrance="{elevator_entrance}"/>

      <!-- NavigateToElevatorEntrance -->
      <Nav2NavigateToPose2
          entry_pose="{elevator_entrance}"/>

      <!-- ElevatorSequence -->
      <WaitRobotNearElevator
          elevator_yaml="{elev_yaml}"
          world_frame="map"
          base_frame="base_link"
          timeout="120.0"/>

      <CallElevatorToFloor
          elevator_yaml="{elev_yaml}"
          elevator_ns="{elevator_ns}"
          floor_idx="{current_floor}"
          timeout="30.0"/>

      <WaitCabinAtTarget
          elevator_yaml="{elev_yaml}"
          elevator_ns="{elevator_ns}"
          floor_idx="{current_floor}"
          timeout="20.0"/>

      <Fallback name="EnsureDoorOpenForBoarding">
        <WaitDoorOpen
            elevator_yaml="{elev_yaml}"
            elevator_ns="{elevator_ns}"
            want_open="true"
            open_threshold="0.7"
            timeout="2.0"/>
        <Sequence name="OpenThenWaitForBoarding">
          <SetElevatorDoor
              elevator_yaml="{elev_yaml}"
              elevator_ns="{elevator_ns}"
              open="true"/>
          <WaitDoorOpen
              elevator_yaml="{elev_yaml}"
              elevator_ns="{elevator_ns}"
              want_open="true"
              open_threshold="0.7"
              timeout="5.0"/>
        </Sequence>
      </Fallback>

      <GetCabinGoal
        elevator_yaml="{elev_yaml}"
        floor_idx="{current_floor}"
        cabin_goal="{cabin_goal}"/>

      <Nav2NavigateToPose2 entry_pose="{cabin_goal}"/>

      <WaitRobotInsideCabin
          elevator_yaml="{elev_yaml}"
          world_frame="map"
          base_frame="base_link"
          timeout="60.0"/>

      <Fallback name="EnsureDoorClosedBeforeDepart">
        <Sequence name="IfOpenThenClose">
          <WaitDoorOpen
              elevator_yaml="{elev_yaml}"
              elevator_ns="{elevator_ns}"
              want_open="true"
              open_threshold="0.7"
              timeout="5.0"/>
          <SetElevatorDoor
              elevator_yaml="{elev_yaml}"
              elevator_ns="{elevator_ns}"
              open="false"/>
          <WaitDoorOpen
              elevator_yaml="{elev_yaml}"
              elevator_ns="{elevator_ns}"
              want_open="false"
              open_threshold="0.02"
              timeout="5.0"/>
        </Sequence>
        <AlwaysSuccess/>
      </Fallback>

      <CallElevatorToFloor
          elevator_yaml="{elev_yaml}"
          elevator_ns="{elevator_ns}"
          floor_idx="{target_floor}"
          timeout="30.0"/>

      <WaitCabinAtTarget
          elevator_yaml="{elev_yaml}"
          elevator_ns="{elevator_ns}"
          floor_idx="{target_floor}"
          timeout="20.0"/>

      <Fallback name="EnsureDoorOpenForExit">
        <WaitDoorOpen
            elevator_yaml="{elev_yaml}"
            elevator_ns="{elevator_ns}"
            want_open="true"
            open_threshold="0.7"
            timeout="2.0"/>
        <Sequence name="OpenThenWaitForExit">
          <SetElevatorDoor
              elevator_yaml="{elev_yaml}"
              elevator_ns="{elevator_ns}"
              open="true"/>
          <WaitDoorOpen
              elevator_yaml="{elev_yaml}"
              elevator_ns="{elevator_ns}"
              want_open="true"
              open_threshold="0.7"
              timeout="5.0"/>
        </Sequence>
      </Fallback>

      <Nav2NavigateToPose2 entry_pose="{elevator_entrance}"/>

      <WaitRobotOutsideElevator
          elevator_yaml="{elev_yaml}"
          world_frame="map"
          base_frame="base_link"
          timeout="60.0"/>

      <Fallback name="EnsureDoorClosedAfterExit">
        <Sequence name="IfOpenThenCloseAfterExit">
          <WaitDoorOpen
              elevator_yaml="{elev_yaml}"
              elevator_ns="{elevator_ns}"
              want_open="true"
              open_threshold="0.7"
              timeout="5.0"/>
          <SetElevatorDoor
              elevator_yaml="{elev_yaml}"
              elevator_ns="{elevator_ns}"
              open="false"/>
          <WaitDoorOpen
              elevator_yaml="{elev_yaml}"
              elevator_ns="{elevator_ns}"
              want_open="false"
              open_threshold="0.02"
              timeout="5.0"/>
        </Sequence>
        <AlwaysSuccess/>
      </Fallback>

      <Ok/>

    </Sequence>
  </BehaviorTree>


  <BehaviorTree ID="StairsSubtree">
    <Sequence name="GoToTargetFloorViaStairs">

      <Fallback name="AlreadyThereOrMove">

        <Sequence name="AlreadyThere">
          <Inverter>
            <CheckFloorDifferent
                current_floor="{current_floor}"
                target_floor="{target_floor}"
                floors_to_climb="{floors_to_climb}"
                direction="{direction}"/>
          </Inverter>
        </Sequence>

        <Sequence name="MoveViaStairs">

          <CheckFloorDifferent
              current_floor="{current_floor}"
              target_floor="{target_floor}"
              floors_to_climb="{floors_to_climb}"
              direction="{direction}"/>

          <Repeat name="RepeatByFloors" num_cycles="{floors_to_climb}">

            <Sequence name="OneFloorStep">

              <GetCurrentFloor
                  map_frame="map"
                  base_frame="base_link"
                  floor0_z="0.0"
                  floor1_z="5.0"
                  floor2_z="10.0"
                  current_floor="{current_floor}"/>

              <ComputeNextFloor
                  current_floor="{current_floor}"
                  direction="{direction}"
                  next_floor="{next_floor}"/>

              <SelectStairEntrance
                  current_floor="{current_floor}"
                  target_floor="{next_floor}"
                  direction="{direction}"
                  stair_yaml="/home/home/ros2_ws/install/stair_bt/share/stair_bt/config/stairs.yaml"
                  map_frame="map"
                  stair_id="{stair_id}"
                  entry_pose="{stair_entry_pose}"
                  entry_yaw="{entry_yaw}"
                  landing_turn1_deg="{landing_turn1_deg}"
                  landing_move_d="{landing_move_d}"
                  landing_turn2_deg="{landing_turn2_deg}"
                  dz_mid="{dz_mid}"
                  dz_top="{dz_top}"
                  flight_speed="{flight_speed}"
                  landing_speed="{landing_speed}"/>

              <Nav2NavigateToPose2
                  entry_pose="{stair_entry_pose}"/>

              <AlignWithStairs
                  stair_yaml="/home/home/ros2_ws/install/stair_bt/share/stair_bt/config/stairs.yaml"
                  stair_id="{stair_id}"
                  direction="{direction}"
                  yaw_tolerance="0.02"
                  angular_speed="0.5"
                  timeout="10.0"
                  world_frame="map"
                  base_frame="base_link"/>

              <ClimbFlightRL
                  direction="{direction}"
                  target_level="mid"
                  timeout="60.0"
                  linear_speed="{flight_speed}"
                  dz_from_entry="{dz_mid}"
                  reference_z="{stair_ref_z}"
                  world_frame="map"
                  base_frame="base_link"/>

              <MoveForwardDistance
                  distance="0.6"
                  linear_speed="{landing_speed}"
                  odom_frame="odom"
                  base_frame="base_link"/>

              <TurnRelative
                  angle_deg="{landing_turn1_deg}"
                  angular_speed="0.5"
                  yaw_tolerance="0.02"
                  timeout="30.0"
                  ref_frame="map"
                  base_frame="base_link"/>

              <MoveForwardDistance
                  distance="{landing_move_d}"
                  linear_speed="{landing_speed}"
                  odom_frame="odom"
                  base_frame="base_link"/>

              <TurnRelative
                  angle_deg="{landing_turn2_deg}"
                  angular_speed="0.5"
                  yaw_tolerance="0.02"
                  timeout="30.0"
                  ref_frame="map"
                  base_frame="base_link"/>

              <ClimbFlightRL
                  direction="{direction}"
                  target_level="top"
                  timeout="60.0"
                  linear_speed="{flight_speed}"
                  dz_from_entry="{dz_top}"
                  reference_z="{stair_ref_z}"
                  world_frame="map"
                  base_frame="base_link"/>

              <MoveForwardDistance
                  distance="0.6"
                  linear_speed="{landing_speed}"
                  odom_frame="odom"
                  base_frame="base_link"/>

            </Sequence>
          </Repeat>

          <GetCurrentFloor
              map_frame="map"
              base_frame="base_link"
              floor0_z="0.0"
              floor1_z="5.0"
              floor2_z="10.0"
              current_floor="{current_floor}"/>

          <Inverter>
            <CheckFloorDifferent
                current_floor="{current_floor}"
                target_floor="{target_floor}"
                floors_to_climb="{floors_to_climb}"
                direction="{direction}"/>
          </Inverter>

        </Sequence>
      </Fallback>

    </Sequence>
  </BehaviorTree>

</root>
